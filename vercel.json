{
  "redirects": [
    { "source": "/vs/cuebill", "destination": "/vs/cueflow", "permanent": true },
    { "source": "/cuebill", "destination": "/cuebill-alternative", "permanent": true },
    { "source": "/cueflow", "destination": "/cueflow-alternative", "permanent": true },
    { "source": "/reviews/cuebill", "destination": "/cuebill-alternative", "permanent": true },
    { "source": "/reviews/cueflow", "destination": "/cueflow-review", "permanent": true },
    { "source": "/alternatives/cuebill", "destination": "/cuebill-alternative", "permanent": true },
    { "source": "/alternatives/cueflow", "destination": "/cueflow-alternative", "permanent": true },
    { "source": "/is-cueflow-worth-it", "destination": "/is-cuebill-worth-it", "permanent": true },
    { "source": "/cuebill-vs-cuetronix", "destination": "/cueflow-vs-cuetronix", "permanent": true },
    { "source": "/cuebook", "destination": "/cuebook-alternative", "permanent": true },
    { "source": "/reviews/cuebook", "destination": "/cuebook-review", "permanent": true },
    { "source": "/alternatives/cuebook", "destination": "/cuebook-alternative", "permanent": true },
    { "source": "/clubsync", "destination": "/clubsync-alternative", "permanent": true },
    { "source": "/club-sync-india", "destination": "/club-sync-india-alternative", "permanent": true },
    { "source": "/vs/club-sync-india", "destination": "/vs/clubsync", "permanent": true },
    { "source": "/reviews/clubsync", "destination": "/clubsync-review", "permanent": true },
    { "source": "/reviews/club-sync-india", "destination": "/clubsync-review", "permanent": true },
    { "source": "/alternatives/clubsync", "destination": "/clubsync-alternative", "permanent": true },
    { "source": "/alternatives/club-sync-india", "destination": "/club-sync-india-alternative", "permanent": true },
    { "source": "/club-sync-vs-cuetronix", "destination": "/clubsync-vs-cuetronix", "permanent": true }
  ],
  "rewrites": [
    { "source": "/((?!api/|assets/|.*\\.(?:js|mjs|css|map|png|jpg|jpeg|gif|svg|ico|webp|avif|woff|woff2|ttf|otf|txt|xml|webmanifest|json)$).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate, max-age=0" }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate, max-age=0" }
      ]
    },
    {
      "source": "/build-meta.json",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate, max-age=0" }
      ]
    },
    {
      "source": "/((?!api/|assets/).*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate, max-age=0" },
        {
          "key": "Content-Security-Policy-Report-Only",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://checkout.razorpay.com https://cdn.razorpay.com https://assets.calendly.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://assets.calendly.com; img-src 'self' data: blob: https:; font-src 'self' data: https://fonts.gstatic.com; connect-src 'self' https://*.supabase.co wss://*.supabase.co https://openrouter.ai https://*.razorpay.com https://*.vercel.app https://calendly.com https://*.calendly.com; frame-src 'self' https://*.razorpay.com https://calendly.com https://*.calendly.com; object-src 'none'; base-uri 'self'; form-action 'self'"
        },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://checkout.razorpay.com https://cdn.razorpay.com https://assets.calendly.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://assets.calendly.com; img-src 'self' data: blob: https:; font-src 'self' data: https://fonts.gstatic.com; connect-src 'self' https://*.supabase.co wss://*.supabase.co https://openrouter.ai https://*.razorpay.com https://*.vercel.app https://calendly.com https://*.calendly.com; frame-src 'self' https://*.razorpay.com https://calendly.com https://*.calendly.com; object-src 'none'; base-uri 'self'; form-action 'self'"
        }
      ]
    }
  ],
  "functions": {
    "api/**/*.ts": {
      "includeFiles": "src/{server,types,utils,lib}/**"
    }
  }
}
