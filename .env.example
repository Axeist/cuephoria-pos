## Client (Vite)
VITE_SUPABASE_PROJECT_ID="your_project_ref"
VITE_SUPABASE_URL="https://your_project_ref.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your_supabase_anon_key"
VITE_GEMINI_API_KEY="your_gemini_api_key"
# Cuephoria AI — OpenRouter proxy endpoint (optional override for local dev /
# staging). Defaults to `/api/admin/ai-chat` when unset, which is the secure
# server proxy deployed with the app.
# VITE_AI_PROXY_URL="http://localhost:3000/api/admin/ai-chat"
# Dev-only fallback: set this to go direct from the browser to OpenRouter
# (skipping the proxy). Do NOT set this in production — the key will be
# bundled into the client JS. Use the server `OPENROUTER_API_KEY` instead.
# VITE_OPENROUTER_API_KEY="sk-or-v1-..."

## Server (Vercel Functions)
# Required for signed admin session cookie
ADMIN_SESSION_SECRET="change_me_to_a_long_random_string"

# Required for server-side admin APIs (do NOT expose to browser)
SUPABASE_SERVICE_ROLE_KEY="your_supabase_service_role_key"

# Cuephoria AI — server-side OpenRouter key. Read ONLY by /api/admin/ai-chat
# and never sent to the browser. Add this in Vercel → Settings → Environment
# Variables. Set a monthly spend cap at https://openrouter.ai/settings/credits.
OPENROUTER_API_KEY="sk-or-v1-your_openrouter_key"

## Transactional Email (Resend) - required for signup verification/reset mails
RESEND_API_KEY="re_your_resend_api_key"
RESEND_FROM="Cuephoria <hello@yourdomain.com>"
RESEND_REPLY_TO="support@yourdomain.com"
APP_BASE_URL="https://admin.cuephoria.in"

## Optional: Razorpay (used by /api/razorpay/*)
RAZORPAY_MODE="test" # test | live
RAZORPAY_KEY_ID_TEST="your_test_key_id"
RAZORPAY_KEY_SECRET_TEST="your_test_key_secret"
RAZORPAY_KEY_ID_LIVE="your_live_key_id"
RAZORPAY_KEY_SECRET_LIVE="your_live_key_secret"
# Lite branch public booking (/lite/public/booking) — separate Razorpay merchant (live required when RAZORPAY_MODE=live)
RAZORPAY_KEY_ID_LIVE_LITE="rzp_live_xxxxxxxx"
RAZORPAY_KEY_SECRET_LIVE_LITE="xxxxxxxx"
# Optional: distinct test keys for lite; if unset, lite booking uses main test keys in test mode
# RAZORPAY_KEY_ID_TEST_LITE="rzp_test_xxxxxxxx"
# RAZORPAY_KEY_SECRET_TEST_LITE="xxxxxxxx"

