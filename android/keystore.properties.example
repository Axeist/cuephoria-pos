# Copy to android/keystore.properties (gitignored) and fill in after creating your upload keystore.
# Never commit keystore.properties or *.keystore files.
#
# keytool -genkey -v -keystore ~/cuetronix-upload.keystore -alias cuetronix-upload \
#   -keyalg RSA -keysize 2048 -validity 10000

storeFile=/absolute/path/to/cuetronix-upload.keystore
storePassword=your-store-password
keyAlias=cuetronix-upload
keyPassword=your-key-password
